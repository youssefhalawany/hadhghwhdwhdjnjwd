{
  "name": "circle-k-enterprise",
  "productName": "Circle K Enterprise",
  "version": "1.0.0",
  "description": "Enterprise Level POS & Financial Reporting System",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "author": "Youssef Halawany",
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.circlek.enterprise",
    "productName": "Circle K Enterprise",
    "mac": {
      "icon": "assets/icon.png",
      "category": "public.app-category.business",
      "target": ["dmg"]
    },
    "win": {
      "icon": "assets/icon.png",
      "target": ["nsis"]
    }
  }
}
